@if (IsOpen)
{
    <div class="modal-backdrop">
        <div class="panel modal-card" role="dialog" aria-modal="true" aria-labelledby="confirmation-title">
            <p class="eyebrow">Warning</p>
            <h3 class="panel-title" id="confirmation-title">@Title</h3>
            <p class="panel-copy">@Message</p>
            <div class="modal-actions">
                <button class="button button-muted" @onclick="OnCancel">
                    Cancel
                </button>
                <button class="button button-danger" @onclick="OnConfirm">
                    Confirm delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string Title { get; set; } = "Confirm Action";

    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }
}
