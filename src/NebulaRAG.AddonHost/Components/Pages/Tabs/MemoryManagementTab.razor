@using System.Globalization
@using NebulaRAG.Core.Configuration
@using NebulaRAG.Core.Embeddings
@using NebulaRAG.Core.Models
@using NebulaRAG.Core.Services
@using NebulaRAG.Core.Storage
@inject RagManagementService ManagementService
@inject PostgresRagStore RagStore
@inject IEmbeddingGenerator EmbeddingGenerator
@inject RagSettings Settings

<div class="section-stack">
    <section class="panel section-panel compact">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Scope</p>
                <h2 class="panel-title">@GetMemoryScopeHeading()</h2>
                <p class="panel-copy">@GetMemoryScopeDescription()</p>
            </div>
            <span class="badge">@(_memoryStats?.TotalMemories ?? 0) visible</span>
        </div>
    </section>

    <section class="metric-grid">
        <article class="metric-card accent">
            <span class="metric-label">Scoped memories</span>
            <span class="metric-value">@(_memoryStats?.TotalMemories ?? 0)</span>
            <p class="metric-footnote">Project-owned memory rows currently visible in the dashboard.</p>
        </article>
        <article class="metric-card secondary">
            <span class="metric-label">Recent growth</span>
            <span class="metric-value">@(_memoryStats?.Recent24HoursCount ?? 0)</span>
            <p class="metric-footnote">New memory rows created in the last 24 hours.</p>
        </article>
        <article class="metric-card tertiary">
            <span class="metric-label">Top-level sessions</span>
            <span class="metric-value">@(_memoryStats?.DistinctSessionCount ?? 0)</span>
            <p class="metric-footnote">Sessions remain visible as lineage, not as the primary dashboard filter.</p>
        </article>
        <article class="metric-card warning">
            <span class="metric-label">Search results</span>
            <span class="metric-value">@_memorySearchResults.Count</span>
            <p class="metric-footnote">Matches from the latest semantic search inside the active project slice.</p>
        </article>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <section class="status-banner @(_statusIsError ? "error" : "ok")">@_statusMessage</section>
    }

    <section class="split-grid">
        <article class="panel section-panel compact">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Create</p>
                    <h2 class="panel-title">Store memory</h2>
                    <p class="panel-copy">Create a new memory row for the selected project. Session id is optional lineage only.</p>
                </div>
            </div>

            <div class="form-grid">
                <label class="field">
                    <span class="field-label">Project id</span>
                    <input class="text-input mono" @bind="_memoryProjectId" placeholder="Project id" />
                </label>
                <label class="field">
                    <span class="field-label">Session id</span>
                    <input class="text-input mono" @bind="_memorySessionId" placeholder="Optional lineage session id" />
                </label>
                <label class="field">
                    <span class="field-label">Type</span>
                    <select class="select-input" @bind="_memoryType">
                        <option value="episodic">episodic</option>
                        <option value="semantic">semantic</option>
                        <option value="procedural">procedural</option>
                    </select>
                </label>
                <label class="field">
                    <span class="field-label">Tags</span>
                    <input class="text-input" @bind="_memoryTagsText" placeholder="Comma-separated tags" />
                </label>
                <label class="field span-2">
                    <span class="field-label">Content</span>
                    <textarea class="textarea-input" @bind="_memoryContent" placeholder="Memory content"></textarea>
                </label>
                <div class="field span-2">
                    <button class="button button-secondary" @onclick="CreateMemoryAsync">Create memory</button>
                </div>
            </div>
        </article>

        <article class="panel section-panel compact">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Browse</p>
                    <h2 class="panel-title">Project ledger</h2>
                    <p class="panel-copy">Browse and search memory per project, then purge a project slice when the ledger needs a clean reset.</p>
                </div>
            </div>

            <div class="form-grid">
                <label class="field">
                    <span class="field-label">Project id</span>
                    <input class="text-input mono" @bind="_memoryProjectFilter" placeholder="Project filter" />
                </label>
                <label class="field">
                    <span class="field-label">Type filter</span>
                    <select class="select-input" @bind="_memoryListType">
                        <option value="">all</option>
                        <option value="episodic">episodic</option>
                        <option value="semantic">semantic</option>
                        <option value="procedural">procedural</option>
                    </select>
                </label>
                <label class="field span-2">
                    <span class="field-label">Tag filter</span>
                    <input class="text-input" @bind="_memoryListTag" placeholder="Optional tag filter" />
                </label>
                <label class="field span-2">
                    <span class="field-label">Search text</span>
                    <input class="text-input" @bind="_memorySearchText" placeholder="Search within the active project memory" />
                </label>
                <label class="field">
                    <span class="field-label">Search limit</span>
                    <input class="text-input" type="number" min="1" max="100" @bind="_memorySearchLimit" />
                </label>
                <div class="field">
                    <button class="button button-primary" @onclick="SearchMemoriesAsync">Search memories</button>
                </div>
                <div class="field">
                    <button class="button button-muted" @onclick="LoadMemoriesAsync">Refresh ledger</button>
                </div>
                <div class="field">
                    <button class="button button-danger" @onclick="OpenPurgeProjectConfirm">Purge project memory</button>
                </div>
            </div>
        </article>
    </section>

    <section class="panel section-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Editor</p>
                <h2 class="panel-title">Update or delete memory</h2>
                <p class="panel-copy">Load a memory row from the ledger, edit it, or remove it outright.</p>
            </div>
        </div>

        <div class="form-grid">
            <label class="field">
                <span class="field-label">Memory id</span>
                <input class="text-input" type="number" @bind="_editMemoryId" placeholder="Memory id" />
            </label>
            <label class="field">
                <span class="field-label">Type</span>
                <select class="select-input" @bind="_editMemoryType">
                    <option value="episodic">episodic</option>
                    <option value="semantic">semantic</option>
                    <option value="procedural">procedural</option>
                </select>
            </label>
            <label class="field span-2">
                <span class="field-label">Tags</span>
                <input class="text-input" @bind="_editMemoryTagsText" placeholder="Comma-separated tags" />
            </label>
            <label class="field span-2">
                <span class="field-label">Content</span>
                <textarea class="textarea-input" @bind="_editMemoryContent" placeholder="Updated memory content"></textarea>
            </label>
            <div class="field">
                <button class="button button-secondary" @onclick="UpdateMemoryAsync">Update memory</button>
            </div>
            <div class="field">
                <button class="button button-danger" @onclick="OpenDeleteEditorConfirm">Delete memory</button>
            </div>
        </div>
    </section>

    <section class="panel table-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Recall</p>
                <h2 class="panel-title">Memory search results</h2>
                <p class="panel-copy">Semantic matches scoped to the active project slice.</p>
            </div>
            <span class="badge">@_memorySearchResults.Count matches</span>
        </div>

        <div class="table-shell">
            @if (_memorySearchResults.Count == 0)
            {
                <div class="empty-state">No search results yet. Run a project-scoped memory search to inspect relevant rows.</div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Project / Session</th>
                            <th>Score</th>
                            <th>Type</th>
                            <th>Content</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _memorySearchResults)
                        {
                            <tr>
                                <td><div class="cell-title">@row.Id</div></td>
                                <td>
                                    <div class="cell-title mono">@(row.ProjectId ?? "unscoped")</div>
                                    <div class="cell-subtitle mono">@row.SessionId</div>
                                </td>
                                <td><div class="cell-title">@row.Score.ToString("F3", CultureInfo.InvariantCulture)</div></td>
                                <td><div class="cell-title">@row.Type</div></td>
                                <td class="truncate-cell"><div class="cell-title">@TrimText(row.Content, 180)</div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </section>

    @if (_reviewQueueCount > 0)
    {
        <div class="alert alert-warning mb-4">
            <span class="font-bold">@_reviewQueueCount long-term @(_reviewQueueCount == 1 ? "memory" : "memories") due for review</span>
            <button class="btn btn-sm btn-outline ml-4" @onclick="ToggleReviewQueue">
                @(_showReviewQueue ? "Hide" : "Show") Queue
            </button>
        </div>
    }

    @if (_showReviewQueue && _reviewQueue.Count > 0)
    {
        <div class="card bg-base-200 mb-6">
            <div class="card-body p-4">
                <div class="flex justify-between items-center mb-3">
                    <h3 class="font-semibold">Review Queue</h3>
                    <button class="btn btn-xs btn-ghost" @onclick="MarkAllReviewedAsync">Mark all reviewed</button>
                </div>
                @foreach (var item in _reviewQueue)
                {
                    <div class="border border-base-300 rounded p-3 mb-2 text-sm">
                        <div class="flex justify-between items-start gap-2">
                            <p class="flex-1">@item.Content</p>
                            <span class="badge @(item.ReviewStatus == "overdue" ? "badge-error" : "badge-warning") badge-sm shrink-0">
                                @item.ReviewStatus
                            </span>
                        </div>
                        <div class="text-xs text-base-content/50 mt-1">
                            Created @item.CreatedAtUtc.ToString("yyyy-MM-dd") ·
                            Last reviewed: @(item.LastReviewedAtUtc?.ToString("yyyy-MM-dd") ?? "never") ·
                            Due: @item.ReviewDueAtUtc.ToString("yyyy-MM-dd")
                        </div>
                        <div class="flex gap-2 mt-2">
                            <button class="btn btn-xs btn-ghost" @onclick="() => ConfirmReviewAsync(item.Id)">Confirm</button>
                            <button class="btn btn-xs btn-ghost text-error" @onclick="() => DeleteMemoryAsync(item.Id)">Delete</button>
                            <button class="btn btn-xs btn-outline" @onclick="() => DemoteToShortTermAsync(item.Id)">Demote to ST</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <section class="panel table-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Ledger</p>
                <h2 class="panel-title">Memory records</h2>
                <p class="panel-copy">View, edit, delete, or purge memory at project scope.</p>
            </div>
            <span class="badge">@_memories.Count rows</span>
        </div>

        <div class="table-shell">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Project / Session</th>
                        <th>Type</th>
                        <th>Content</th>
                        <th>Tags</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var memory in _memories)
                    {
                        <tr>
                            <td><div class="cell-title">@memory.Id</div></td>
                            <td>
                                <div class="cell-title mono">@(memory.ProjectId ?? "unscoped")</div>
                                <div class="cell-subtitle mono">@memory.SessionId</div>
                            </td>
                            <td>
                                <div class="cell-title">@memory.Type</div>
                                <span class="badge @(memory.Tier == MemoryTier.LongTerm ? "badge-primary" : "badge-ghost") badge-sm">
                                    @(memory.Tier == MemoryTier.LongTerm ? "LT" : "ST")
                                </span>
                            </td>
                            <td class="truncate-cell"><div class="cell-title">@TrimText(memory.Content, 160)</div></td>
                            <td><div class="cell-title">@string.Join(", ", memory.Tags)</div></td>
                            <td>
                                <div class="table-actions">
                                    <button class="button button-muted" @onclick="() => LoadMemoryIntoEditor(memory)">Edit</button>
                                    <button class="button button-danger" @onclick="() => OpenDeleteRowConfirm(memory.Id)">Delete</button>
                                    @if (memory.Tier == MemoryTier.ShortTerm)
                                    {
                                        <button class="button button-muted" @onclick="() => PromoteToLongTermAsync(memory.Id)">Promote to LT</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<ConfirmationModal IsOpen="@_showDeleteMemoryConfirm" Title="Delete Memory" Message="Delete this memory entry permanently?" OnConfirm="ConfirmDeleteMemoryAsync" OnCancel="CloseDeleteConfirm" />
<ConfirmationModal IsOpen="@_showPurgeProjectConfirm" Title="Purge Project Memory" Message="Delete every memory row for the active project?" OnConfirm="ConfirmPurgeProjectAsync" OnCancel="ClosePurgeProjectConfirm" />

@code {
    [Parameter]
    public long RefreshNonce { get; set; }

    [Parameter]
    public string? SelectedProjectId { get; set; }

    [Parameter]
    public EventCallback OnDataChanged { get; set; }

    private readonly List<MemoryRecord> _memories = new();
    private readonly List<MemorySearchResult> _memorySearchResults = new();
    private List<MemoryReviewResult> _reviewQueue = [];
    private int _reviewQueueCount = 0;
    private bool _showReviewQueue = false;
    private long _lastRefreshNonce = -1;
    private string? _lastSelectedProjectId;
    private bool _statusIsError;
    private bool _showDeleteMemoryConfirm;
    private bool _showPurgeProjectConfirm;
    private long _pendingDeleteMemoryId;
    private MemoryDashboardStats? _memoryStats;
    private string? _statusMessage;
    private string _memorySessionId = string.Empty;
    private string _memoryProjectId = string.Empty;
    private string _memoryProjectFilter = string.Empty;
    private string _memoryType = "semantic";
    private string _memoryTagsText = string.Empty;
    private string _memoryContent = string.Empty;
    private string _memorySearchText = string.Empty;
    private int _memorySearchLimit = 20;
    private string _memoryListTag = string.Empty;
    private string _memoryListType = string.Empty;
    private long _editMemoryId;
    private string _editMemoryType = "semantic";
    private string _editMemoryTagsText = string.Empty;
    private string _editMemoryContent = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        if (_lastRefreshNonce == RefreshNonce && string.Equals(_lastSelectedProjectId, SelectedProjectId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _lastRefreshNonce = RefreshNonce;
        _lastSelectedProjectId = SelectedProjectId;
        ApplyProjectSelectionDefaults();
        await LoadMemoriesAsync();
    }

    private async Task CreateMemoryAsync()
    {
        if (string.IsNullOrWhiteSpace(_memoryContent))
        {
            SetStatus("Memory content is required.", isError: true);
            return;
        }

        try
        {
            var tags = ParseTags(_memoryTagsText);
            var embedding = EmbeddingGenerator.GenerateEmbedding(_memoryContent.Trim(), Settings.Ingestion.VectorDimensions);
            var id = await RagStore.CreateMemoryAsync(
                sessionId: NormalizeOptional(_memorySessionId),
                projectId: GetEffectiveProjectId(_memoryProjectId),
                type: _memoryType,
                content: _memoryContent.Trim(),
                tags: tags,
                embedding: embedding);

            _memoryContent = string.Empty;
            _memoryTagsText = string.Empty;
            SetStatus($"Memory created with id {id}.");
            await NotifyDataChangedAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Create memory failed: {exception.Message}", isError: true);
        }
    }

    private async Task LoadMemoriesAsync()
    {
        try
        {
            var projectId = GetActiveProjectFilter();
            var memories = await ManagementService.ListMemoriesAsync(limit: 300, type: NormalizeOptional(_memoryListType), tag: NormalizeOptional(_memoryListTag), projectId: projectId);
            _memoryStats = await ManagementService.GetMemoryStatsAsync(projectId: projectId);
            _memories.Clear();
            _memories.AddRange(memories);
            await LoadReviewQueueAsync();
            SetStatus($"Loaded {_memories.Count} memories.");
        }
        catch (Exception exception)
        {
            SetStatus($"Load memories failed: {exception.Message}", isError: true);
        }
    }

    private async Task SearchMemoriesAsync()
    {
        if (string.IsNullOrWhiteSpace(_memorySearchText))
        {
            SetStatus("Memory search text is required.", isError: true);
            return;
        }

        try
        {
            var projectId = GetActiveProjectFilter();
            var results = await ManagementService.SearchMemoriesAsync(
                _memorySearchText.Trim(),
                Math.Clamp(_memorySearchLimit, 1, 100),
                tag: NormalizeOptional(_memoryListTag),
                type: NormalizeOptional(_memoryListType),
                projectId: projectId);

            _memorySearchResults.Clear();
            _memorySearchResults.AddRange(results);
            SetStatus($"Memory search returned {_memorySearchResults.Count} rows.");
        }
        catch (Exception exception)
        {
            SetStatus($"Memory search failed: {exception.Message}", isError: true);
        }
    }

    private void LoadMemoryIntoEditor(MemoryRecord memory)
    {
        _editMemoryId = memory.Id;
        _editMemoryType = memory.Type;
        _editMemoryContent = memory.Content;
        _editMemoryTagsText = string.Join(",", memory.Tags);
    }

    private async Task UpdateMemoryAsync()
    {
        if (_editMemoryId <= 0)
        {
            SetStatus("Memory id is required for update.", isError: true);
            return;
        }

        if (string.IsNullOrWhiteSpace(_editMemoryContent))
        {
            SetStatus("Updated content cannot be empty.", isError: true);
            return;
        }

        try
        {
            var updatedTags = ParseTags(_editMemoryTagsText);
            var embedding = EmbeddingGenerator.GenerateEmbedding(_editMemoryContent.Trim(), Settings.Ingestion.VectorDimensions);
            var updated = await RagStore.UpdateMemoryAsync(_editMemoryId, _editMemoryType, _editMemoryContent.Trim(), updatedTags, embedding);
            SetStatus(updated ? $"Memory {_editMemoryId} updated." : $"Memory {_editMemoryId} was not found.", isError: !updated);
            await NotifyDataChangedAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Update memory failed: {exception.Message}", isError: true);
        }
    }

    private void OpenDeleteEditorConfirm()
    {
        if (_editMemoryId <= 0)
        {
            SetStatus("Memory id is required for delete.", isError: true);
            return;
        }

        _pendingDeleteMemoryId = _editMemoryId;
        _showDeleteMemoryConfirm = true;
    }

    private void OpenDeleteRowConfirm(long memoryId)
    {
        _pendingDeleteMemoryId = memoryId;
        _showDeleteMemoryConfirm = true;
    }

    private async Task ConfirmDeleteMemoryAsync()
    {
        try
        {
            var deleted = await RagStore.DeleteMemoryAsync(_pendingDeleteMemoryId);
            SetStatus(deleted ? $"Memory {_pendingDeleteMemoryId} deleted." : $"Memory {_pendingDeleteMemoryId} was not found.", isError: !deleted);
            await NotifyDataChangedAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Delete memory failed: {exception.Message}", isError: true);
        }
        finally
        {
            CloseDeleteConfirm();
        }
    }

    private void OpenPurgeProjectConfirm()
    {
        if (string.IsNullOrWhiteSpace(GetActiveProjectFilter()))
        {
            SetStatus("Select or enter a project id before purging memory.", isError: true);
            return;
        }

        _showPurgeProjectConfirm = true;
    }

    private async Task ConfirmPurgeProjectAsync()
    {
        try
        {
            var projectId = GetActiveProjectFilter();
            if (string.IsNullOrWhiteSpace(projectId))
            {
                SetStatus("Project id is required for purge.", isError: true);
                return;
            }

            var deleted = await RagStore.DeleteMemoriesByProjectAsync(projectId);
            SetStatus($"Deleted {deleted} memory rows from {projectId}.");
            await NotifyDataChangedAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Project memory purge failed: {exception.Message}", isError: true);
        }
        finally
        {
            ClosePurgeProjectConfirm();
        }
    }

    private void CloseDeleteConfirm()
    {
        _showDeleteMemoryConfirm = false;
        _pendingDeleteMemoryId = 0;
    }

    private void ClosePurgeProjectConfirm()
    {
        _showPurgeProjectConfirm = false;
    }

    private async Task NotifyDataChangedAsync()
    {
        await LoadMemoriesAsync();
        if (OnDataChanged.HasDelegate)
        {
            await OnDataChanged.InvokeAsync();
        }
    }

    private async Task LoadReviewQueueAsync()
    {
        var results = await RagStore.ListMemoriesDueForReviewAsync(
            Settings.AutoMemory.LongTermReviewIntervalDays, limit: 50);
        _reviewQueue = results.ToList();
        _reviewQueueCount = _reviewQueue.Count;
    }

    private void ToggleReviewQueue() => _showReviewQueue = !_showReviewQueue;

    private async Task ConfirmReviewAsync(long id)
    {
        await RagStore.UpdateMemoryAsync(id, null, null, null, null, stampReviewed: true);
        await LoadReviewQueueAsync();
        StateHasChanged();
    }

    private async Task MarkAllReviewedAsync()
    {
        foreach (var item in _reviewQueue)
            await RagStore.UpdateMemoryAsync(item.Id, null, null, null, null, stampReviewed: true);
        await LoadReviewQueueAsync();
        StateHasChanged();
    }

    private async Task DeleteMemoryAsync(long id)
    {
        await RagStore.DeleteMemoryAsync(id);
        await NotifyDataChangedAsync();
    }

    private async Task DemoteToShortTermAsync(long id)
    {
        await RagStore.UpdateMemoryAsync(id, null, null, null, null, stampReviewed: false, tier: MemoryTier.ShortTerm);
        await LoadReviewQueueAsync();
        StateHasChanged();
    }

    private async Task PromoteToLongTermAsync(long id)
    {
        await RagStore.UpdateMemoryAsync(id, null, null, null, null, stampReviewed: false, tier: MemoryTier.LongTerm);
        await NotifyDataChangedAsync();
        StateHasChanged();
    }

    private void SetStatus(string message, bool isError = false)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }

    private static IReadOnlyList<string> ParseTags(string rawTags)
    {
        return rawTags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private string? GetActiveProjectFilter()
    {
        return GetEffectiveProjectId(_memoryProjectFilter);
    }

    private string? GetEffectiveProjectId(string? candidate)
    {
        return NormalizeOptional(candidate) ?? NormalizeOptional(SelectedProjectId);
    }

    private string GetMemoryScopeHeading()
    {
        return string.IsNullOrWhiteSpace(GetActiveProjectFilter())
            ? "Memory CRUD across all projects"
            : $"Memory CRUD for {GetActiveProjectFilter()}";
    }

    private string GetMemoryScopeDescription()
    {
        return string.IsNullOrWhiteSpace(GetActiveProjectFilter())
            ? "Select a project from the shell to pin the ledger, or browse the full memory store when you need a global view."
            : "The selected project owns the ledger, search, edit, delete, and purge actions on this screen.";
    }

    private void ApplyProjectSelectionDefaults()
    {
        if (string.IsNullOrWhiteSpace(SelectedProjectId))
        {
            return;
        }

        _memoryProjectFilter = SelectedProjectId;
        _memoryProjectId = SelectedProjectId;
    }

    private static string TrimText(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value;
        }

        return $"{value[..maxLength]}...";
    }
}