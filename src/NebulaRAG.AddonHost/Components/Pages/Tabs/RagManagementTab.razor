@using System.Globalization

<div class="section-stack">
    <section class="panel section-panel compact">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Scope</p>
                <h2 class="panel-title">@GetScopeHeading()</h2>
                <p class="panel-copy">@GetScopeDescription()</p>
            </div>
            <span class="badge">@_documents.Count visible docs</span>
        </div>
    </section>

    <section class="metric-grid">
        <article class="metric-card accent">
            <span class="metric-label">Visible documents</span>
            <span class="metric-value">@_documents.Count</span>
            <p class="metric-footnote">Project-owned indexed documents currently surfaced by the dashboard.</p>
        </article>
        <article class="metric-card secondary">
            <span class="metric-label">Stored chunks</span>
            <span class="metric-value">@_documents.Sum(document => document.ChunkCount)</span>
            <p class="metric-footnote">Chunk volume in the active document ledger.</p>
        </article>
        <article class="metric-card tertiary">
            <span class="metric-label">Search filter</span>
            <span class="metric-value">@(_documentSearchText.Length == 0 ? "all" : "filtered")</span>
            <p class="metric-footnote">Document search matches source paths and indexed content previews.</p>
        </article>
        <article class="metric-card warning">
            <span class="metric-label">Latest index</span>
            <span class="metric-value">@GetLatestIndexTime()</span>
            <p class="metric-footnote">Most recent indexed timestamp across visible documents.</p>
        </article>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <section class="status-banner @(_statusIsError ? "error" : "ok")">@_statusMessage</section>
    }

    <section class="split-grid">
        <article class="panel section-panel compact">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Ingestion</p>
                    <h2 class="panel-title">Index source path</h2>
                    <p class="panel-copy">Start a filesystem indexing pass directly from the add-on host to add or refresh document inventory.</p>
                </div>
            </div>

            <div class="form-grid">
                <label class="field span-2">
                    <span class="field-label">Source path</span>
                    <input class="text-input mono" @bind="_indexPath" placeholder="/share" />
                </label>
                <div class="field span-2">
                    <button class="button button-secondary" @onclick="IndexSourceAsync">Index now</button>
                </div>
            </div>
        </article>

        <article class="panel section-panel compact">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Browse</p>
                    <h2 class="panel-title">Project document ledger</h2>
                    <p class="panel-copy">Search by source path or content preview, then purge a project slice when the index needs correction.</p>
                </div>
            </div>

            <div class="form-grid">
                <label class="field">
                    <span class="field-label">Project id</span>
                    <input class="text-input mono" @bind="_projectFilter" placeholder="Project filter" />
                </label>
                <label class="field">
                    <span class="field-label">Search text</span>
                    <input class="text-input" @bind="_documentSearchText" placeholder="Search source path or content" />
                </label>
                <div class="field">
                    <button class="button button-primary" @onclick="RefreshDocumentsAsync">Refresh documents</button>
                </div>
                <div class="field">
                    <button class="button button-danger" @onclick="OpenPurgeProjectConfirm">Purge project docs</button>
                </div>
            </div>
        </article>
    </section>

    <section class="panel section-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Editor</p>
                <h2 class="panel-title">View and edit indexed document</h2>
                <p class="panel-copy">Open one indexed document, inspect its reconstructed content, edit it in place, or remove it.</p>
            </div>
        </div>

        <div class="form-grid">
            <label class="field span-2">
                <span class="field-label">Source path</span>
                <input class="text-input mono" @bind="_editSourcePath" placeholder="Stored source path" />
            </label>
            <label class="field span-2">
                <span class="field-label">Project id</span>
                <input class="text-input mono" @bind="_editProjectId" placeholder="Derived project id" />
            </label>
            <label class="field span-2">
                <span class="field-label">Content</span>
                <textarea class="textarea-input" @bind="_editContent" placeholder="Indexed document content"></textarea>
            </label>
            <div class="field">
                <button class="button button-muted" @onclick="LoadSelectedDocumentAsync">Load document</button>
            </div>
            <div class="field">
                <button class="button button-secondary" @onclick="SaveDocumentAsync">Save document</button>
            </div>
            <div class="field">
                <button class="button button-danger" @onclick="OpenDeleteDocumentConfirm">Delete document</button>
            </div>
        </div>
    </section>

    <section class="panel table-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Ledger</p>
                <h2 class="panel-title">Indexed documents</h2>
                <p class="panel-copy">Project-scoped document list with view, edit, delete, and purge flows.</p>
            </div>
            <span class="badge">@_documents.Count tracked</span>
        </div>

        <div class="table-shell">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Source</th>
                        <th>Project</th>
                        <th>Chunks / Tokens</th>
                        <th>Indexed</th>
                        <th>Preview</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var document in _documents.OrderByDescending(document => document.IndexedAt))
                    {
                        <tr>
                            <td><div class="cell-title mono">@document.SourcePath</div></td>
                            <td><div class="cell-title mono">@(document.ProjectId ?? "unscoped")</div></td>
                            <td>
                                <div class="cell-title">@document.ChunkCount chunks</div>
                                <div class="cell-subtitle">@document.TokenCount tokens</div>
                            </td>
                            <td><div class="cell-title">@document.IndexedAt.ToLocalTime().ToString("MMM dd HH:mm", CultureInfo.InvariantCulture)</div></td>
                            <td class="truncate-cell"><div class="cell-title">@TrimText(document.PreviewText, 180)</div></td>
                            <td>
                                <div class="table-actions">
                                    <button class="button button-muted" @onclick="() => LoadDocumentIntoEditorAsync(document.SourcePath)">View</button>
                                    <button class="button button-danger" @onclick="() => OpenDeleteDocumentConfirm(document.SourcePath)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<ConfirmationModal IsOpen="@_showDeleteDocumentConfirm" Title="Delete Indexed Document" Message="Delete this indexed document and all its chunks?" OnConfirm="ConfirmDeleteDocumentAsync" OnCancel="CloseAllConfirm" />
<ConfirmationModal IsOpen="@_showPurgeProjectConfirm" Title="Purge Project Documents" Message="Delete every indexed document and chunk for the active project?" OnConfirm="ConfirmPurgeProjectAsync" OnCancel="CloseAllConfirm" />