@using System.Globalization
@using NebulaRAG.Core.Models
@using NebulaRAG.Core.Storage
@inject PostgresPlanStore PlanStore

<div class="section-stack">
    <section class="panel section-panel compact">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Scope</p>
                <h2 class="panel-title">@GetPlansScopeHeading()</h2>
                <p class="panel-copy">@GetPlansScopeDescription()</p>
            </div>
            <span class="badge">@_plans.Count visible plans</span>
        </div>
    </section>

    <section class="metric-grid">
        <article class="metric-card accent">
            <span class="metric-label">Loaded plans</span>
            <span class="metric-value">@_plans.Count</span>
            <p class="metric-footnote">Plans currently loaded for the active project ledger.</p>
        </article>
        <article class="metric-card secondary">
            <span class="metric-label">Active plans</span>
            <span class="metric-value">@_plans.Count(plan => plan.Status == PlanStatus.Active)</span>
            <p class="metric-footnote">Execution tracks still in motion.</p>
        </article>
        <article class="metric-card tertiary">
            <span class="metric-label">Selected tasks</span>
            <span class="metric-value">@_selectedPlanTasks.Count</span>
            <p class="metric-footnote">Tasks loaded for the plan currently in the editor.</p>
        </article>
        <article class="metric-card warning">
            <span class="metric-label">Project scope</span>
            <span class="metric-value mono">@(GetActiveProjectFilter() ?? "all")</span>
            <p class="metric-footnote">Session ids still exist for lineage, not for dashboard browsing.</p>
        </article>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <section class="status-banner @(_statusIsError ? "error" : "ok")">@_statusMessage</section>
    }

    <section class="split-grid">
        <article class="panel section-panel compact">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Create</p>
                    <h2 class="panel-title">Create plan</h2>
                    <p class="panel-copy">Create a plan inside a project. Session id remains available for agent lineage but is not required for browsing.</p>
                </div>
            </div>

            <div class="form-grid">
                <label class="field">
                    <span class="field-label">Project id</span>
                    <input class="text-input mono" @bind="_newPlanProjectId" placeholder="Project id" />
                </label>
                <label class="field">
                    <span class="field-label">Session id</span>
                    <input class="text-input mono" @bind="_newPlanSessionId" placeholder="Optional lineage session id" />
                </label>
                <label class="field span-2">
                    <span class="field-label">Plan name</span>
                    <input class="text-input" @bind="_newPlanName" placeholder="Plan name" />
                </label>
                <label class="field span-2">
                    <span class="field-label">Description</span>
                    <textarea class="textarea-input" @bind="_newPlanDescription" placeholder="Description"></textarea>
                </label>
                <label class="field span-2">
                    <span class="field-label">Initial tasks</span>
                    <textarea class="textarea-input" @bind="_newPlanTasksText" placeholder="One task per line"></textarea>
                </label>
                <div class="field span-2">
                    <button class="button button-secondary" @onclick="CreatePlanAsync">Create plan</button>
                </div>
            </div>
        </article>

        <article class="panel section-panel compact">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Browse</p>
                    <h2 class="panel-title">Project plan ledger</h2>
                    <p class="panel-copy">Refresh the active project slice or purge every plan under one project.</p>
                </div>
            </div>

            <div class="form-grid">
                <label class="field span-2">
                    <span class="field-label">Project id</span>
                    <input class="text-input mono" @bind="_planProjectFilter" placeholder="Project filter" />
                </label>
                <div class="field">
                    <button class="button button-primary" @onclick="LoadPlansAsync">Refresh plans</button>
                </div>
                <div class="field">
                    <button class="button button-danger" @onclick="OpenPurgeProjectConfirm">Purge project plans</button>
                </div>
            </div>
        </article>
    </section>

    <section class="panel section-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Editor</p>
                <h2 class="panel-title">View and edit plan</h2>
                <p class="panel-copy">Load a plan from the ledger, edit its name or description, move its lifecycle status, or delete it.</p>
            </div>
        </div>

        <div class="form-grid">
            <label class="field">
                <span class="field-label">Plan id</span>
                <input class="text-input" type="number" @bind="_editPlanId" placeholder="Plan id" />
            </label>
            <label class="field">
                <span class="field-label">Project id</span>
                <input class="text-input mono" @bind="_editPlanProjectId" readonly />
            </label>
            <label class="field">
                <span class="field-label">Session id</span>
                <input class="text-input mono" @bind="_editPlanSessionId" readonly />
            </label>
            <label class="field">
                <span class="field-label">Status</span>
                <select class="select-input" @bind="_editPlanStatus">
                    @foreach (var status in Enum.GetValues<PlanStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </label>
            <label class="field span-2">
                <span class="field-label">Plan name</span>
                <input class="text-input" @bind="_editPlanName" placeholder="Plan name" />
            </label>
            <label class="field span-2">
                <span class="field-label">Description</span>
                <textarea class="textarea-input" @bind="_editPlanDescription" placeholder="Description"></textarea>
            </label>
            <div class="field">
                <button class="button button-muted" @onclick="LoadSelectedPlanAsync">Load plan</button>
            </div>
            <div class="field">
                <button class="button button-secondary" @onclick="SavePlanAsync">Save plan</button>
            </div>
            <div class="field">
                <button class="button button-danger" @onclick="OpenDeletePlanConfirm">Delete plan</button>
            </div>
        </div>
    </section>

    <section class="panel table-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Tasks</p>
                <h2 class="panel-title">Selected plan tasks</h2>
                <p class="panel-copy">Task view for the plan currently loaded in the editor.</p>
            </div>
            <span class="badge">@_selectedPlanTasks.Count tasks</span>
        </div>

        <div class="table-shell">
            @if (_selectedPlanTasks.Count == 0)
            {
                <div class="empty-state">Load a plan from the ledger to inspect its task list.</div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Task id</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in _selectedPlanTasks)
                        {
                            <tr>
                                <td><div class="cell-title">@task.Id</div></td>
                                <td><div class="cell-title">@task.Title</div></td>
                                <td><div class="cell-title">@task.Status</div></td>
                                <td><div class="cell-title">@task.Priority</div></td>
                                <td>
                                    @if (task.Status != NebulaRAG.Core.Models.TaskStatus.Completed)
                                    {
                                        <div class="table-actions">
                                            <button class="button button-secondary" @onclick="() => CompleteTaskAsync(task.Id)">Complete</button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </section>

    <section class="panel table-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Ledger</p>
                <h2 class="panel-title">Plans</h2>
                <p class="panel-copy">Project-scoped plan list with direct inspect and delete actions.</p>
            </div>
            <span class="badge">@_plans.Count plans</span>
        </div>

        <div class="table-shell">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Project / Session</th>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var plan in _plans.OrderByDescending(plan => plan.UpdatedAt))
                    {
                        <tr>
                            <td><div class="cell-title">@plan.Id</div></td>
                            <td>
                                <div class="cell-title mono">@plan.ProjectId</div>
                                <div class="cell-subtitle mono">@plan.SessionId</div>
                            </td>
                            <td><div class="cell-title">@plan.Name</div></td>
                            <td><div class="cell-title">@plan.Status</div></td>
                            <td><div class="cell-title">@plan.UpdatedAt.ToLocalTime().ToString("MMM dd HH:mm", CultureInfo.InvariantCulture)</div></td>
                            <td>
                                <div class="table-actions">
                                    <button class="button button-muted" @onclick="() => LoadPlanIntoEditor(plan)">Inspect</button>
                                    <button class="button button-danger" @onclick="() => OpenDeletePlanConfirm(plan.Id)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<ConfirmationModal IsOpen="@_showDeletePlanConfirm" Title="Delete Plan" Message="Delete this plan and all of its tasks?" OnConfirm="ConfirmDeletePlanAsync" OnCancel="CloseDeletePlanConfirm" />
<ConfirmationModal IsOpen="@_showPurgeProjectConfirm" Title="Purge Project Plans" Message="Delete every plan and task for the active project?" OnConfirm="ConfirmPurgeProjectAsync" OnCancel="ClosePurgeProjectConfirm" />

@code {
    [Parameter]
    public long RefreshNonce { get; set; }

    [Parameter]
    public string? SelectedProjectId { get; set; }

    [Parameter]
    public EventCallback OnDataChanged { get; set; }

    private readonly List<PlanRecord> _plans = new();
    private readonly List<PlanTaskRecord> _selectedPlanTasks = new();
    private long _lastRefreshNonce = -1;
    private string? _lastSelectedProjectId;
    private bool _statusIsError;
    private bool _showDeletePlanConfirm;
    private bool _showPurgeProjectConfirm;
    private string? _statusMessage;
    private string _planProjectFilter = string.Empty;
    private string _newPlanProjectId = string.Empty;
    private string _newPlanSessionId = "dashboard-session";
    private string _newPlanName = string.Empty;
    private string _newPlanDescription = string.Empty;
    private string _newPlanTasksText = string.Empty;
    private long _editPlanId;
    private string _editPlanProjectId = string.Empty;
    private string _editPlanSessionId = string.Empty;
    private string _editPlanName = string.Empty;
    private string _editPlanDescription = string.Empty;
    private PlanStatus _editPlanStatus = PlanStatus.Draft;
    private PlanStatus _loadedPlanStatus = PlanStatus.Draft;
    private long _pendingDeletePlanId;

    protected override async Task OnParametersSetAsync()
    {
        if (_lastRefreshNonce == RefreshNonce && string.Equals(_lastSelectedProjectId, SelectedProjectId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _lastRefreshNonce = RefreshNonce;
        _lastSelectedProjectId = SelectedProjectId;
        ApplyProjectSelectionDefaults();
        await LoadPlansAsync();
    }

    private async Task LoadPlansAsync()
    {
        try
        {
            var plans = await PlanStore.ListPlansAsync(GetActiveProjectFilter());
            _plans.Clear();
            _plans.AddRange(plans);

            if (_editPlanId > 0 && !_plans.Any(plan => plan.Id == _editPlanId))
            {
                ResetPlanEditor();
            }

            SetStatus($"Loaded {_plans.Count} plans.");
        }
        catch (Exception exception)
        {
            SetStatus($"Load plans failed: {exception.Message}", isError: true);
        }
    }

    private async Task CreatePlanAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPlanProjectId) || string.IsNullOrWhiteSpace(_newPlanName))
        {
            SetStatus("Project id and plan name are required.", isError: true);
            return;
        }

        try
        {
            var taskRows = _newPlanTasksText
                .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(task => new CreateTaskRequest(task, null, "normal", "dashboard-ui"))
                .ToList();

            var request = new CreatePlanRequest(
                _newPlanProjectId.Trim(),
                NormalizeOptional(_newPlanSessionId) ?? "dashboard-session",
                _newPlanName.Trim(),
                NormalizeOptional(_newPlanDescription),
                taskRows,
                "dashboard-ui");

            var created = await PlanStore.CreatePlanAsync(request);
            _newPlanName = string.Empty;
            _newPlanDescription = string.Empty;
            _newPlanTasksText = string.Empty;
            _planProjectFilter = request.ProjectId;
            SetStatus($"Plan created: {created.planId} with {created.taskIds.Count} tasks.");
            await NotifyDataChangedAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Create plan failed: {exception.Message}", isError: true);
        }
    }

    private async Task LoadSelectedPlanAsync()
    {
        if (_editPlanId <= 0)
        {
            SetStatus("Plan id is required to load the plan editor.", isError: true);
            return;
        }

        try
        {
            var planWithTasks = await PlanStore.GetPlanWithTasksByIdAsync(_editPlanId);
            LoadPlanIntoEditor(planWithTasks.plan);
            _selectedPlanTasks.Clear();
            _selectedPlanTasks.AddRange(planWithTasks.tasks);
            SetStatus($"Loaded plan {_editPlanId} with {_selectedPlanTasks.Count} tasks.");
        }
        catch (Exception exception)
        {
            SetStatus($"Load plan failed: {exception.Message}", isError: true);
        }
    }

    private async Task SavePlanAsync()
    {
        if (_editPlanId <= 0)
        {
            SetStatus("Load a plan before saving changes.", isError: true);
            return;
        }

        if (string.IsNullOrWhiteSpace(_editPlanName))
        {
            SetStatus("Plan name cannot be empty.", isError: true);
            return;
        }

        try
        {
            var updateRequest = new UpdatePlanRequest(_editPlanName.Trim(), NormalizeOptional(_editPlanDescription), "dashboard-ui");
            await PlanStore.UpdatePlanAsync(_editPlanId, updateRequest);

            if (_editPlanStatus != _loadedPlanStatus)
            {
                await PlanStore.UpdatePlanStatusAsync(_editPlanId, _editPlanStatus, "dashboard-ui", "Updated from dashboard");
            }

            SetStatus($"Plan {_editPlanId} updated.");
            await NotifyDataChangedAsync();
            await LoadSelectedPlanAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Save plan failed: {exception.Message}", isError: true);
        }
    }

    private async Task CompleteTaskAsync(long taskId)
    {
        try
        {
            await PlanStore.CompleteTaskAsync(taskId, "dashboard-ui", "Completed from dashboard");
            SetStatus($"Task {taskId} marked completed.");
            await LoadSelectedPlanAsync();
            await OnDataChanged.InvokeAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Complete task failed: {exception.Message}", isError: true);
        }
    }

    private void LoadPlanIntoEditor(PlanRecord plan)
    {
        _editPlanId = plan.Id;
        _editPlanProjectId = plan.ProjectId;
        _editPlanSessionId = plan.SessionId;
        _editPlanName = plan.Name;
        _editPlanDescription = plan.Description ?? string.Empty;
        _editPlanStatus = plan.Status;
        _loadedPlanStatus = plan.Status;
    }

    private void OpenDeletePlanConfirm()
    {
        if (_editPlanId <= 0)
        {
            SetStatus("Load a plan before deleting it.", isError: true);
            return;
        }

        _pendingDeletePlanId = _editPlanId;
        _showDeletePlanConfirm = true;
    }

    private void OpenDeletePlanConfirm(long planId)
    {
        _pendingDeletePlanId = planId;
        _showDeletePlanConfirm = true;
    }

    private async Task ConfirmDeletePlanAsync()
    {
        try
        {
            var deleted = await PlanStore.DeletePlanAsync(_pendingDeletePlanId);
            SetStatus(deleted ? $"Plan {_pendingDeletePlanId} deleted." : $"Plan {_pendingDeletePlanId} was not found.", isError: !deleted);
            if (deleted && _editPlanId == _pendingDeletePlanId)
            {
                ResetPlanEditor();
            }

            await NotifyDataChangedAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Delete plan failed: {exception.Message}", isError: true);
        }
        finally
        {
            CloseDeletePlanConfirm();
        }
    }

    private void OpenPurgeProjectConfirm()
    {
        if (string.IsNullOrWhiteSpace(GetActiveProjectFilter()))
        {
            SetStatus("Select or enter a project id before purging plans.", isError: true);
            return;
        }

        _showPurgeProjectConfirm = true;
    }

    private async Task ConfirmPurgeProjectAsync()
    {
        try
        {
            var projectId = GetActiveProjectFilter();
            if (string.IsNullOrWhiteSpace(projectId))
            {
                SetStatus("Project id is required for purge.", isError: true);
                return;
            }

            var deleted = await PlanStore.DeletePlansByProjectAsync(projectId);
            ResetPlanEditor();
            SetStatus($"Deleted {deleted} plans from {projectId}.");
            await NotifyDataChangedAsync();
        }
        catch (Exception exception)
        {
            SetStatus($"Project plan purge failed: {exception.Message}", isError: true);
        }
        finally
        {
            ClosePurgeProjectConfirm();
        }
    }

    private void CloseDeletePlanConfirm()
    {
        _showDeletePlanConfirm = false;
        _pendingDeletePlanId = 0;
    }

    private void ClosePurgeProjectConfirm()
    {
        _showPurgeProjectConfirm = false;
    }

    private async Task NotifyDataChangedAsync()
    {
        await LoadPlansAsync();
        if (OnDataChanged.HasDelegate)
        {
            await OnDataChanged.InvokeAsync();
        }
    }

    private void ResetPlanEditor()
    {
        _editPlanId = 0;
        _editPlanProjectId = string.Empty;
        _editPlanSessionId = string.Empty;
        _editPlanName = string.Empty;
        _editPlanDescription = string.Empty;
        _editPlanStatus = PlanStatus.Draft;
        _loadedPlanStatus = PlanStatus.Draft;
        _selectedPlanTasks.Clear();
    }

    private void SetStatus(string message, bool isError = false)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private string? GetActiveProjectFilter()
    {
        return NormalizeOptional(_planProjectFilter) ?? NormalizeOptional(SelectedProjectId);
    }

    private string GetPlansScopeHeading()
    {
        return string.IsNullOrWhiteSpace(GetActiveProjectFilter())
            ? "Plan CRUD across all projects"
            : $"Plan CRUD for {GetActiveProjectFilter()}";
    }

    private string GetPlansScopeDescription()
    {
        return string.IsNullOrWhiteSpace(GetActiveProjectFilter())
            ? "Select a project from the shell to pin the plan ledger, or browse everything when you need a global audit view."
            : "The selected project owns the plan list, editor, delete flow, and project purge action on this screen.";
    }

    private void ApplyProjectSelectionDefaults()
    {
        if (string.IsNullOrWhiteSpace(SelectedProjectId))
        {
            return;
        }

        _planProjectFilter = SelectedProjectId;
        _newPlanProjectId = SelectedProjectId;
    }
}