{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NoProfile -File .github/nebula/hooks/Invoke-NebulaAgentHook.ps1 -Agent Claude -Event SessionStart",
            "timeout": 10,
            "statusMessage": "Loading Nebula hook context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NoProfile -File .github/nebula/hooks/Invoke-NebulaAgentHook.ps1 -Agent Claude -Event PreToolUse",
            "timeout": 10,
            "statusMessage": "Checking Nebula shell guardrails"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__nebula-rag__.*|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NoProfile -File .github/nebula/hooks/Invoke-NebulaAgentHook.ps1 -Agent Claude -Event PostToolUseFailure",
            "timeout": 10,
            "statusMessage": "Capturing Nebula failure details"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NoProfile -File .github/nebula/hooks/Invoke-NebulaAgentHook.ps1 -Agent Claude -Event StopFailure",
            "timeout": 10,
            "statusMessage": "Capturing Claude failure details"
          }
        ]
      }
    ]
  }
}
